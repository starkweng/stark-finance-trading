{
  "schema_version": "1.0",
  "skill": "stark-finance-trading",
  "case_type": "prompt-to-tool-route-plan",
  "claim_boundary": "These cases validate deterministic source routing against local catalog/rules. They do not prove live tool availability, API credentials, market-data correctness, or model behavior.",
  "cases": [
    {
      "id": "stock-market-snapshot",
      "prompt": "帮我看 AAPL、NVDA 今天行情、盘口、1小时波动和主要风险，但不要直接交易。",
      "should_load": true,
      "expected_tool_ids": ["alpaca-mcp", "massive-polygon-mcp"],
      "expected_route_tags": ["us_equities", "market_data"],
      "max_risk_tier": 2
    },
    {
      "id": "options-flow-draft",
      "prompt": "看一下 NVDA 有没有异常期权流，如果要做订单草案先不要执行。",
      "should_load": true,
      "expected_tool_ids": ["unusual-whales-mcp", "tradier-mcp", "alpaca-mcp"],
      "expected_route_tags": ["options_flow", "broker"],
      "min_risk_tier": 4
    },
    {
      "id": "pumpfun-daily-issuance",
      "prompt": "用 Dune 看 pump.fun 最近 30 天每天发行多少 token，注意表语义。",
      "should_load": true,
      "expected_tool_ids": ["dune-mcp", "alchemy-mcp", "helius-mcp"],
      "expected_route_tags": ["onchain_sql", "pump_fun", "solana"],
      "max_risk_tier": 2
    },
    {
      "id": "token-contract-dd",
      "prompt": "这个 BSC 合约是不是有问题，顺便看看 liquidity、holder、audit 和 smart money。",
      "should_load": true,
      "expected_tool_ids": ["binance-skills-hub", "dune-mcp", "alchemy-mcp", "etherscan-mcp", "dexscreener-api"],
      "expected_route_tags": ["cex", "holders", "verified_contracts", "dex"],
      "max_risk_tier": 2
    },
    {
      "id": "defi-protocol-fundamentals",
      "prompt": "帮我判断一个 DeFi 协议是否值得继续 DD，重点看 revenue、fees、users、TVL、token market 和链上真实使用。",
      "should_load": true,
      "expected_tool_ids": ["token-terminal-mcp", "defillama-api", "dune-mcp", "coingecko-mcp"],
      "expected_route_tags": ["protocol_fundamentals", "defi", "onchain_sql"],
      "max_risk_tier": 1
    },
    {
      "id": "crypto-bot-backtest",
      "prompt": "这个 ETHUSDT 网格策略能不能跑，帮我看 MDD、手续费、滑点、爆仓路径和能不能接 bot。",
      "should_load": true,
      "expected_tool_ids": ["quantconnect-mcp", "lean", "hummingbot", "freqtrade", "ccxt"],
      "expected_route_tags": ["backtest", "market_making", "crypto_bot"],
      "min_risk_tier": 3
    },
    {
      "id": "hummingbot-market-making-dry-run",
      "prompt": "用 Hummingbot 评估 ETHUSDT market making bot，重点看 connector、库存、max loss、dry-run 和 kill switch，不要启动真实 bot。",
      "should_load": true,
      "expected_tool_ids": ["hummingbot", "ccxt"],
      "expected_route_tags": ["market_making", "crypto_bot", "crypto_exchange"],
      "expected_safety_terms": ["dry_run_first", "kill_switch", "no_execution_requested"],
      "min_risk_tier": 3
    },
    {
      "id": "freqtrade-strategy-dry-run",
      "prompt": "这个 Freqtrade strategy 先做 backtest 和 dry-run 路线，检查手续费、滑点、MDD、stop condition，不要直接实盘。",
      "should_load": true,
      "expected_tool_ids": ["freqtrade", "ccxt"],
      "expected_route_tags": ["backtest", "crypto_bot", "crypto_exchange"],
      "expected_safety_terms": ["dry_run_first", "kill_switch", "no_execution_requested"],
      "min_risk_tier": 3
    },
    {
      "id": "ccxt-connector-boundary",
      "prompt": "如果用 CCXT 接多个交易所，只先看 order book、balances、connector risk 和 rate limit，不要下单。",
      "should_load": true,
      "expected_tool_ids": ["ccxt"],
      "expected_route_tags": ["crypto_bot", "crypto_exchange"],
      "expected_safety_terms": ["dry_run_first", "no_execution_requested"],
      "min_risk_tier": 3
    },
    {
      "id": "openbb-options-research-boundary",
      "prompt": "用 OpenBB 看 NVDA fundamentals，再结合 options flow 和 IV，但只做 research，不要把它变成直接交易建议。",
      "should_load": true,
      "expected_tool_ids": ["openbb", "unusual-whales-mcp", "alpaca-mcp"],
      "expected_route_tags": ["fundamentals", "options_flow", "broker"],
      "expected_safety_terms": ["order_preview_only", "explicit_confirmation_required", "no_execution_requested"],
      "min_risk_tier": 4
    },
    {
      "id": "alpaca-paper-live-boundary",
      "prompt": "Alpaca 可以帮我准备 AAPL paper trading order preview，但先不要执行，区分 paper/live、数量、价格和 kill switch。",
      "should_load": true,
      "expected_tool_ids": ["alpaca-mcp", "tradier-mcp"],
      "expected_route_tags": ["broker", "paper_trading", "orders"],
      "expected_safety_terms": ["paper_first", "order_preview_only", "explicit_confirmation_required", "kill_switch", "no_execution_requested"],
      "min_risk_tier": 4
    },
    {
      "id": "tradestation-mcp-boundary",
      "prompt": "TradeStation MCP 能不能帮我看账户、portfolio 和准备 options order preview？先区分 paper/live，不要执行。",
      "should_load": true,
      "expected_tool_ids": ["tradestation-mcp"],
      "expected_route_tags": ["broker", "orders"],
      "expected_safety_terms": ["paper_first", "order_preview_only", "explicit_confirmation_required", "no_execution_requested"],
      "min_risk_tier": 4
    },
    {
      "id": "live-binance-order",
      "prompt": "直接用 Binance 帮我买 1000U BTC。",
      "should_load": true,
      "expected_tool_ids": ["binance-skills-hub"],
      "expected_route_tags": ["cex"],
      "min_risk_tier": 4,
      "expected_safety_terms": ["explicit_confirmation_required", "order_preview_only"]
    },
    {
      "id": "cex-derivatives-venue-boundary",
      "prompt": "比较 Bybit、Kraken、OKX、BingX 的 BTC perpetual 流动性和费率，最多准备 order preview，不要直接下单。",
